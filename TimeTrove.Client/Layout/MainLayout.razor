@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
<FluentLayout>
    <FluentHeader>
        TimeTrove
    </FluentHeader>
    <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
        <AuthorizeView>
            <Authorized>
                <NavMenu/>
            </Authorized>
            <NotAuthorized>
                
                
            </NotAuthorized>
        </AuthorizeView>
        <FluentBodyContent>
            <div class="content">
                @Body
            </div>
        </FluentBodyContent>
    </FluentStack>
    <FluentFooter>
        <div>
            All Rights Reserved. Stuart Willows. 2024.
        </div>
    </FluentFooter>
</FluentLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

